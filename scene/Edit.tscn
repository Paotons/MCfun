[sub_resource type="GDScript" id="GDScript_y67ap"]
script/source = "extends Node

@onready var _edit := $\"../FunctionEdit\"
# 文件保存的缓存目录。
var _files_chche_directory : DirAccess

## 当前编辑的文件。
var current_file_path : String
## 当前编辑的文件是否发生更改。
var is_current_file_changed : bool

func _get_text() -> String:
	return _edit.text

func _get_file_list_container() -> FileListContainer:
	return $\"../../FileList/MarginContainer/FileListContainer\"

## 获取文件在缓存里的数据路径。
func get_path_at_chache(path : String) -> String:
	var data_root := FileSystem.data_root
	if not path.begins_with(data_root):
		push_error(\"Not in data_root.\")
		return \"\"
	
	path = path.substr(data_root.length() + (0 if data_root.ends_with(\"/\") else 1))
	return _files_chche_directory.get_current_dir().path_join(path)
## 加载文件。
func load_file(path : String) -> void:
	if path.is_empty():
		_edit.set_function_text(\"\")
		return
	
	var cache_file := get_path_at_chache(path)
	var txt : String
	
	if FileAccess.file_exists(cache_file):
		txt = FileAccess.get_file_as_string(cache_file)
	else:
		txt = FileAccess.get_file_as_string(path)
	
	_edit.set_function_text(txt)
## 把当前编辑的文件保存到缓存。
func save_to_cache() -> void:
	var path := get_path_at_chache(current_file_path)
	
	if path.is_empty():
		return
	
	if not DirAccess.dir_exists_absolute(path):
		_files_chche_directory.make_dir_recursive(path.get_base_dir())
	
	var file := FileAccess.open(path, FileAccess.WRITE)
	file.store_string(_edit.get_text())
	file.close()
## 移除在缓存的文件。
func remove_cache_file(path : String) -> void:
	var cache_path := get_path_at_chache(path)
	
	if FileAccess.file_exists(cache_path):
		DirAccess.remove_absolute(cache_path)

# 初始化缓存文件目录。
func _init_files_chache_directory() -> void:
	var config := ProjectManager.get_current_project().get_project_config()
	var path := FileSystem.data_root.path_join(\"cache/projects\").path_join(config.get_project_name()).path_join(\"files\")
	
	if DirAccess.dir_exists_absolute(path):
		FileSystem.remove_directory(path)
	
	var data_root := DirAccess.open(FileSystem.data_root)
	data_root.make_dir_recursive(path)
	
	_files_chche_directory = DirAccess.open(path)


func _on_function_edit_ready() -> void:
	_init_files_chache_directory()

func _on_function_edit_text_changed() -> void:
	if current_file_path.is_empty():
		return
	
	if not is_current_file_changed:
		is_current_file_changed = true
		_get_file_list_container().set_file_saved_state(current_file_path, false)

func _on_file_list_container_selected_changed(path: String) -> void:
	assert(path.is_empty() or FileAccess.file_exists(path), \"Not find any file.\")
	var file_container := _get_file_list_container()
	
	if not current_file_path.is_empty():
		var current := file_container.get_file_index(current_file_path)
		file_container.set_file_caret_position(current, _edit.get_caret_position())
		save_to_cache()
	
	current_file_path = path
	is_current_file_changed = false
	
	if path.is_empty():
		_edit.editable = false
		_edit.set_function_text(\"\")
	else:
		var index := file_container.get_file_index(path)
		_edit.editable = true
		load_file(path)
		_edit.set_caret_position(file_container.get_file_caret_position(index))

func _on_file_list_container_closed(path: String) -> void:
	remove_cache_file(path)
	if path == current_file_path:
		load_file(\"\")
		current_file_path = \"\"

func _on_file_list_container_saved(path: String) -> void:
	var file := FileAccess.open(path, FileAccess.WRITE)
	
	if current_file_path == path:
		is_current_file_changed = false
		file.store_string(_get_text())
	else:
		var cache_path := get_path_at_chache(path)
		if FileAccess.file_exists(cache_path):
			var string := FileAccess.get_file_as_string(cache_path)
			file.store_string(string)
	file.close()
	
	remove_cache_file(path)

"

[sub_resource type="GDScript" id="GDScript_4o8ox"]
script/source = "extends Node

@onready var _edit := $\"../FunctionEdit\" as FunctionEdit

## 用于检测配置文件高亮颜色的选择。
const CONFIG_HIGHLIGHT_COLOR_SELECT := \"HighLightColor\"
## 用于检测配置文件编辑器行为。
const CONFIG_BEHAVIOR := \"EditBehavior\"
## 用于检测配置文件补全。
const CONFIG_COMPLETION := \"EditCompletion\"

# 初始化配置文件。
func _init_config() -> void:
	var config := FileSystem.config
	if config == null:
		return
	if config.has_section(CONFIG_BEHAVIOR):
		_init_config_behavior()
	if config.has_section(CONFIG_HIGHLIGHT_COLOR_SELECT):
		_init_config_highlight_color()
	if config.has_section(CONFIG_COMPLETION):
		_init_config_completion()
# 初始化配置文件行为。
func _init_config_behavior() -> void:
	var config := FileSystem.config
	_edit.double_input_disabled = not config.get_value(CONFIG_BEHAVIOR, \"double_input_enabled\", true)
	_edit.wrap_mode = config.get_value(CONFIG_BEHAVIOR, \"wrap_mode\", TextEdit.LINE_WRAPPING_NONE)
	_config_edit_double_input_map(config)
func _config_edit_double_input_map(config : ConfigFile) -> void:
	var value : Dictionary = config.get_value(CONFIG_BEHAVIOR, \"double_input_map\", {})
	if value.is_empty():
		return
	var val : Dictionary[String, String] = Dictionary(value, TYPE_STRING, &\"\", null, TYPE_STRING, &\"\", null)
	_edit.set_double_input_map(val)
func _init_config_highlight_color() -> void:
	var config := FileSystem.config
	for key in config.get_section_keys(CONFIG_HIGHLIGHT_COLOR_SELECT):
		var value = config.get_value(CONFIG_HIGHLIGHT_COLOR_SELECT, key)
		if not value is Color:
			continue
		var color := value as Color
		_edit.set_highlight_color(key, color)
func _init_config_completion() -> void:
	var config := FileSystem.config
	var setting := _edit.completion_setting
	_edit.max_code_expleation = floori(config.get_value(CONFIG_COMPLETION, \"max_expletion_count\", 64.0))
	setting.spaceitem_included_space = config.get_value(CONFIG_COMPLETION, \"using_space_name\", true)
	setting.showing_hint_word = config.get_value(CONFIG_COMPLETION, \"showing_hint_word\", true)
	setting.using_hint_word_weight = config.get_value(CONFIG_COMPLETION, \"using_hint_word_weight\", false)

func _on_function_edit_ready() -> void:
	_init_config()
"

