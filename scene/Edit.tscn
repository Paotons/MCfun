[sub_resource type="GDScript" id="GDScript_r0du0"]
resource_name = "Edit"
script/source = "extends FunctionEdit

@export var _error_hint_label : Label

func _errors_list_changed() -> void:
	var line := find_has_error_command()
	if line == -1:
		_error_hint_label.set_text(\"\")
		return
	
	var command := get_command_element(line)
	var head_err : ElementError
	var err_column := 0xFFFF_FFFF
	for err in command.errors:
		if err.column < err_column:
			head_err = err
			err_column = head_err.column
	_error_hint_label.set_text(\"错误 (%d, %d) %s\" % [line + 1, head_err.column, head_err.string])

func _ready() -> void:
	super()
"

[sub_resource type="LabelSettings" id="LabelSettings_r0du0"]
font_color = Color(1, 0, 0, 1)

[sub_resource type="GDScript" id="GDScript_pusrq"]
script/source = "extends Label

func _get_function_edit() -> FunctionEdit:
	return $\"../../../../FunctionEdit\"

func _ready() -> void:
	await get_tree().process_frame
	_update()

func _on_function_edit_caret_changed() -> void:
	_update()

func _update() -> void:
	show_position(_get_function_edit().get_caret_position())

## 显示位置。
func show_position(pos : Vector2i) -> void:
	text = \"%d : %d\" % [pos.x, pos.y + 1]

"

[sub_resource type="GDScript" id="GDScript_qyh5x"]
script/source = "extends FileDialog

func _ready() -> void:
	var config := ProjectManager.get_current_project().get_project_config()
	set_current_dir(config.get_project_path())
"

[sub_resource type="GDScript" id="GDScript_kijkp"]
script/source = "extends AcceptDialog

## 直接关闭。
signal close
## 保存并关闭。
signal save_and_close

func _ready() -> void:
	add_button(\"不保存并关闭\", false, \"0\")
	add_button(\"取消\", false, \"1\")

func _get_file_list_container() -> FileListContainer:
	return $\"../Base/HSplitContainer/FileList/MarginContainer/FileListContainer\"

func _on_confirmed() -> void:
	save_and_close.emit()
	hide()

func _on_custom_action(action: StringName) -> void:
	if action == &\"0\":
		close.emit()
	elif action == &\"1\":
		pass
	hide()
"

[sub_resource type="GDScript" id="GDScript_x5ap5"]
script/source = "extends AcceptDialog

signal saved_and_edit
signal direct_exit

func _ready() -> void:
	add_cancel_button(\"取消\")
	add_button(\"不保存并退出\", false, \"1\")

func _on_confirmed() -> void:
	saved_and_edit.emit()

func _on_custom_action(action: StringName) -> void:
	match action:
		\"1\":
			direct_exit.emit()
"

