[sub_resource type="GDScript" id="GDScript_4ldgq"]
resource_name = "Loader"
script/source = "extends Node

## 初始化结束。
signal initial_finish

enum LoadingType {
	## 加载项目。
	PROJECT,
	## 加载 UI。
	UI,
	## 最大值。
	MAX,
}
const _UI_LOADING_PROCESS_COUNT := 4

var _thread := Thread.new()
var _base_control : EditBaseControl
var _project_process := ProjectOpendProcess.new()

var _mutex := Mutex.new()
var main_process := Vector2i(-1, -1)
var main_name := \"\"
var _control_sub_process := Vector2i(-1, -1)

func _get_function_edit() -> FunctionEdit:
	return $\"../Base/HSplitContainer/VBoxContainer2/FunctionEdit\"
func _get_file_list_container() -> FileListContainer:
	return $\"../Base/HSplitContainer/FileList/MarginContainer/FileListContainer\"
func _get_file_list_container_base_control() -> MarginContainer:
	return $\"../Base/HSplitContainer/FileList\"
func _get_split_container() -> HSplitContainer:
	return $\"../Base/HSplitContainer\"
func _get_export_setting_window() -> ProjectExportSettingWindow:
	return $\"../ProjectExportSetting\"
func _get_error_option_window() -> AcceptDialog:
	return$\"../ErrorOptionWindow\"
# 弹出错误。
func _popup_error(text : String) -> void:
	var window := _get_error_option_window()
	window.dialog_text = text
	window.popup_centered_clamped()

func _get_sub_process() -> Vector2i:
	match main_process.x:
		LoadingType.PROJECT:
			return _project_process.main_process
		LoadingType.UI:
			return _control_sub_process
		_:
			return Vector2i(-1, -1)

## 开始运行，需要在线程中。
func start() -> void:
	_base_control.show_loading()
	
	_project_process.mutex = _mutex
	_thread.start(_on_thread)
	set_process(true)

func _on_thread() -> void:
	const PATH_UI_CFG := \"ui.cfg\"
	
	_mutex.lock()
	main_process.y = LoadingType.MAX
	main_name = \"正在加载配置\"
	main_process.x = LoadingType.PROJECT
	_mutex.unlock()
	
	var project := ProjectManager.get_current_project()
	project._opend(_project_process)
	
	_mutex.lock()
	var errors := _project_process.errors
	_mutex.unlock()
	
	if not errors.is_empty():
		var directory := project.get_project_cache().get_cache_path(ProjectChache.DirectoryType.CACHE).path_join(\"grammar\")
		FileSystem.remove_directory(directory)
		_popup_error.call_deferred(\"语法内容发生错误：\\n%s\" % \"\\n\".join(errors))
		return
	
	var config := ConfigFile.new()
	var path := project.get_project_cache().get_cache_path(ProjectChache.DirectoryType.EDIT)
	if FileAccess.file_exists(path.path_join(PATH_UI_CFG)):
		config.load(path.path_join(PATH_UI_CFG))
	
	_mutex.lock()
	main_name = \"正在加载界面\"
	main_process.x = LoadingType.UI
	_control_sub_process.y = _UI_LOADING_PROCESS_COUNT
	_mutex.unlock()
	
	if not _thread_edit_grammar(config):
		return
	_thread_load_tree(config)
	_thread_load_setting()

func _thread_load_tree(config : ConfigFile) -> void:
	const PATH_EXPORT_UI_CFG := \"export_ui.cfg\"
	
	_thread_edit_split(config)
	_thread_edit_file_list(config)
	
	var path := ProjectManager.get_current_project().get_project_cache().get_cache_path(ProjectChache.DirectoryType.EDIT)
	var exporter_config = ConfigFile.new()
	if FileAccess.file_exists(path.path_join(PATH_EXPORT_UI_CFG)):
		exporter_config.load(path.path_join(PATH_EXPORT_UI_CFG))
	(func() -> void:
		_get_export_setting_window().config_winodw(exporter_config)
	).call_deferred()

func _thread_load_setting() -> void:
	var config := FileSystem.config
	_thread_running_auto_saving(config)

func _process(_delta: float) -> void:
	if _thread.is_started() and not _thread.is_alive():
		_thread.wait_to_finish()
		_base_control.set_loading.call_deferred(\"\", \"\")
		_base_control.hide_lading.call_deferred()
		set_process(false)
		initial_finish.emit()
	
	_mutex.lock()
	var sub_process := _get_sub_process()
	_base_control.set_loading(
		\"%s(%d / %d)\" % [main_name, main_process.x, main_process.y],
		\"%d / %d\" % [sub_process.x, sub_process.y]
	)
	_mutex.unlock()

func _thread_edit_grammar(_config : ConfigFile) -> bool:
	_mutex.lock()
	_control_sub_process.x += 1
	_mutex.unlock()
	
	var project := ProjectManager.get_current_project()
	var grammar := Grammar.new()
	var errors := grammar.open(project.get_project_cache().get_cache_path(ProjectChache.DirectoryType.GRAMMAR))
	
	if not errors.is_empty():
		var directory := project.get_project_cache().get_cache_path(ProjectChache.DirectoryType.CACHE).path_join(\"grammar\")
		FileSystem.remove_directory(directory)
		_popup_error.call_deferred(\"语法内容发生错误：\\n%s\" % \"\\n\".join(errors))
		return false
	
	(func() -> void:
		var edit := _base_control.get_function_edit()
		edit.grammar = grammar
	).call_deferred()
	return true

func _thread_edit_split(config : ConfigFile) -> void:
	var offset_1 : int = config.get_value(\"Split\", \"1\", 50)
	
	(func() -> void:
		_get_split_container().split_offset = offset_1
	).call_deferred()
func _thread_edit_file_list(config : ConfigFile) -> void:
	const SELECTOR := \"FileList\"
	
	_mutex.lock()
	_control_sub_process.x += 1
	_mutex.unlock()
	
	var files : PackedStringArray = config.get_value(SELECTOR, \"file_paths\", [])
	var selected : int = config.get_value(SELECTOR, \"selected\", 0)
	var visible : bool = config.get_value(SELECTOR, \"visible\", true)
	var caret_positions : Array = config.get_value(SELECTOR, \"file_caret_positions\", [])
	(func() -> void:
		var list := _get_file_list_container()
		for path in files:
			list.open_file(path)
		list.select_file(selected)
		_get_file_list_container_base_control().visible = visible
		
		for i in caret_positions.size():
			list.set_file_caret_position(i, caret_positions[i])
		
		if selected < caret_positions.size():
			_get_function_edit().set_caret_position(caret_positions[selected])
	).call_deferred()

func _thread_running_auto_saving(config : ConfigFile) -> void:
	const SELECTOR := \"RunningAutoSaving\"
	_mutex.lock()
	_control_sub_process.x += 1
	_mutex.unlock()
	
	var delta := config.get_value(SELECTOR, \"delta\", 30.0) as float
	(func() -> void:
		var timer := _base_control.get_auto_saving_timer()
		if delta < 0.0:
			timer.stop()
		else:
			timer.wait_time = delta
			timer.start()
	).call_deferred()

func _on_base_control_ready() -> void:
	_base_control = get_parent()
	start()

func _enter_tree() -> void:
	if _thread != null and _thread.is_started() and _thread.is_alive():
		_thread.wait_to_finish()
"

[sub_resource type="GDScript" id="GDScript_3aibf"]
script/source = "extends Node
##
##
## 配置文件。
## FileList -- {file_paths : PackedStringArray, selected : String, visible : bool}
## Split -- {1 : int}

var _base_control : EditBaseControl

func _get_function_edit() -> FunctionEdit:
	return $\"../Base/HSplitContainer/VBoxContainer2/FunctionEdit\"
func _get_file_list_container() -> FileListContainer:
	return $\"../Base/HSplitContainer/FileList/MarginContainer/FileListContainer\"
func _get_file_list_container_base_control() -> MarginContainer:
	return $\"../Base/HSplitContainer/FileList\"
func _get_split_container() -> HSplitContainer:
	return $\"../Base/HSplitContainer\"
func _get_export_setting_window() -> ProjectExportSettingWindow:
	return $\"../ProjectExportSetting\"

func save_scene() -> void:
	const PATH_UI_CFG := \"ui.cfg\"
	const PATH_EXPORT_UI_CFG := \"export_ui.cfg\"
	
	var project := ProjectManager.get_current_project()
	var config := ConfigFile.new()
	var path := project.get_project_cache().get_cache_path(ProjectChache.DirectoryType.EDIT)
	
	_save_split(config)
	_save_file_list(config)
	
	config.save(path.path_join(PATH_UI_CFG))
	
	config = _get_export_setting_window().get_window_config()
	config.save(path.path_join(PATH_EXPORT_UI_CFG))

func _save_split(config : ConfigFile) -> void:
	config.set_value(\"Split\", \"1\", _get_split_container().split_offset)
func _save_file_list(config : ConfigFile) -> void:
	var list := _get_file_list_container()
	config.set_value(\"FileList\", \"file_paths\", list.get_files())
	config.set_value(\"FileList\", \"selected\", list.get_selected_index())
	config.set_value(\"FileList\", \"visible\", _get_file_list_container_base_control().visible)
	_config_file_list_caret_position(list, config)
func _config_file_list_caret_position(list : FileListContainer, config : ConfigFile) -> void:
	var result : Array
	for i in list.get_file_count():
		result.append(list.get_file_caret_position(i))
	if result.size() != 0:
		var selected := list.get_selected_index()
		result[selected] = _get_function_edit().get_caret_position()
	config.set_value(\"FileList\", \"file_caret_positions\", result)

func _on_base_control_ready() -> void:
	_base_control = get_parent()
"

[sub_resource type="GDScript" id="GDScript_ktujv"]
resource_name = "ProjectMenuButton"
script/source = "extends MenuButton

## 重新加载项目。
signal reload_scene
## 退出项目。
signal exit_scene

enum ItemIndex {
	## 设置。
	SETTING,
	
	## 分割符。
	SEPARATOR,
	## 导出。
	EXPORT,
	
	## 分割符。
	SEPARATOR2,
	## 重新加载项目。
	RELOAD,
	## 退出至列表。
	EXIT_TO_LIST,
}

var _is_reload := false

func _ready() -> void:
	get_popup().index_pressed.connect(_on_popup_index_pressed)

func _on_popup_index_pressed(index : int) -> void:
	match index:
		ItemIndex.SETTING: _on_open_project_setting()
		
		ItemIndex.EXPORT: _on_item_export()
		
		ItemIndex.RELOAD: reload()
		ItemIndex.EXIT_TO_LIST: item_exit_to_list()

# 获取项目设置的窗口。
func _get_project_window() -> Window:
	return $\"../../../../../ProjectSetting\"
# 获取项目导出设置窗口。
func _get_project_export_winodw() -> Window:
	return $\"../../../../../ProjectExportSetting\"
func _get_file_list_container() -> FileListContainer:
	return $\"../../../../HSplitContainer/FileList/MarginContainer/FileListContainer\"
func _get_project_exit_option_window() -> Window:
	return $\"../../../../../ProjectExitOptionWindow\"

func _on_open_project_setting() -> void:
	_get_project_window().popup_centered_clamped()

func reload() -> void:
	if not _get_file_list_container().get_not_saved_files().is_empty():
		_is_reload = true
		_get_project_exit_option_window().popup_centered_clamped()
		return
	reload_scene.emit()
func item_exit_to_list() -> void:
	if not _get_file_list_container().get_not_saved_files().is_empty():
		_is_reload = false
		_get_project_exit_option_window().popup_centered_clamped()
		return
	exit_scene.emit()

func _on_item_export() -> void:
	_get_project_export_winodw().popup_centered_clamped()

func _on_project_exit_option_window_direct_exit() -> void:
	if _is_reload:
		reload_scene.emit()
	else:
		exit_scene.emit()

func _on_project_exit_option_window_saved_and_edit() -> void:
	_get_file_list_container().save_all_file()
	if _is_reload:
		reload_scene.emit()
	else:
		exit_scene.emit()
"

[sub_resource type="GDScript" id="GDScript_w0n44"]
resource_name = "FileMenuButton"
script/source = "extends MenuButton

@onready var _list_container := $\"../../../../HSplitContainer/FileList/MarginContainer/FileListContainer\" as FileListContainer

enum ItemIndex {
	## 保存。
	SAVE,
	## 全部保存。
	SAVE_ALL,
	
	## 分割符。
	SEPATATOR,
	## 撤销。
	UNDO,
	## 重做。
	REDO,
	
	## 分割符。
	SEPATATOR2,
	## 打开。
	OPEN,
	
	## 分割符。
	SEPATATOR3,
	## 关闭。
	CLOSE,
	## 清空。
	CLEAR,
	
	## 分割符。
	SEPATATOR4,
	## 创建。
	SYSTEM,
}

# 获取列表窗口。
func _get_file_list_window() -> FileDialog:
	return $\"../../../../../FileListWindow\"
# 获取创建文件都窗口。
func _get_filesystem_window() -> FileSystemWindow:
	return $\"../../../../../FileSystem\"
# 获取保存文件窗口。
func _get_save_file_option_window() -> Window:
	return $\"../../../../../FileSaveOptionWindow\"

func _ready() -> void:
	get_popup().index_pressed.connect(_on_popup_index_pressed)
func _on_popup_index_pressed(index : int) -> void:
	match index:
		ItemIndex.SAVE: _on_item_save()
		ItemIndex.SAVE_ALL: _on_item_save_all()
		
		ItemIndex.UNDO: _on_item_undo()
		ItemIndex.REDO: _on_item_redo()
		
		ItemIndex.OPEN: _on_item_open()
		
		ItemIndex.CLOSE: _on_item_close()
		ItemIndex.CLEAR: _on_item_clear()
		
		ItemIndex.SYSTEM: _on_item_system()

func _on_item_save() -> void:
	_list_container.save_file(_list_container.get_selected())
func _on_item_save_all() -> void:
	for path in _list_container.get_files():
		_list_container.save_file(path)

func _on_item_undo() -> void:
	_list_container.undo()
func _on_item_redo() -> void:
	_list_container.redo()

func _on_item_open() -> void:
	var window := _get_file_list_window()
	window.popup_centered_clamped()

func _on_item_close() -> void:
	var path := _list_container.get_selected()
	if path.is_empty():
		return
	
	if not _list_container.is_file_saved(path):
		_get_save_file_option_window().popup_centered_clamped()
	else:
		_list_container.close_file(path)
func _on_item_clear() -> void:
	for path in _list_container.get_files():
		
		if not _list_container.is_file_saved(path):
			_get_save_file_option_window().popup_centered_clamped()
			break
		else:
			_list_container.close_file(path)
		await get_tree().process_frame

func _on_item_system() -> void:
	_get_filesystem_window().popup_centered_clamped()

func _on_file_list_window_file_selected(path: String) -> void:
	_list_container.open_file(path)

func _on_file_system_file_open(path: String) -> void:
	_list_container.open_file(path)

func _on_file_save_option_window_close() -> void:
	var path := _list_container.get_selected()
	_list_container.close_file(path)

func _on_file_save_option_window_save_and_close() -> void:
	var path := _list_container.get_selected()
	_list_container.saved.emit(path)
	_list_container.close_file(path)
"

[sub_resource type="GDScript" id="GDScript_hr7lf"]
resource_name = "EditMenuButton"
script/source = "extends MenuButton

enum ItemIndex {
	## 撤销。
	UNDO,
	## 重做。
	REDO,
	
	## 分割符。
	SEPARATOR,
	
	## 剪切。
	CUT,
	## 复制。
	COPY,
	## 粘贴。
	PASTE,
	
	## 分割符。
	SEPARATOR2,
	## 全选。
	SELECT_ALL,
	## 选择行。
	SELECT_LINE,
	
	## 分割符。
	SEPARATOR3,
	## 补全。
	ADD_HINT,
	## 取消补全。
	UNDO_HINT,
}

func _ready() -> void:
	get_popup().index_pressed.connect(_on_popup_index_pressed)

func _on_popup_index_pressed(index : int) -> void:
	match index:
		ItemIndex.UNDO : _on_undo()
		ItemIndex.REDO : _on_redo()
		
		ItemIndex.CUT : _on_cut()
		ItemIndex.COPY : _on_copy()
		ItemIndex.PASTE : _on_paste()
		
		ItemIndex.SELECT_ALL : _on_select_all()
		ItemIndex.SELECT_LINE : _on_select_line()
		
		ItemIndex.ADD_HINT : _on_add_hint()
		ItemIndex.UNDO : _on_undo_hint()

func _on_undo() -> void:
	var edit := EditManager.get_edit()
	if edit.has_undo():
		edit.undo()
func _on_redo() -> void:
	var edit := EditManager.get_edit()
	if edit.has_redo():
		edit.redo()

func _on_cut() -> void:
	var edit := EditManager.get_edit()
	edit.cut()
func _on_copy() -> void:
	var edit := EditManager.get_edit()
	edit.copy()
func _on_paste() -> void:
	var edit := EditManager.get_edit()
	edit.paste()

func _on_select_all() -> void:
	var edit := EditManager.get_edit()
	edit.select_all()
func _on_select_line() -> void:
	var edit := EditManager.get_edit()
	var line := edit.get_caret_line()
	if line + 1 < edit.get_line_count():
		edit.select(line, 0, line + 1, 0)
	else:
		var column := edit.get_line(line).length()
		edit.select(line, 0, line, column)

func _on_add_hint() -> void:
	var edit := EditManager.get_edit()
	edit.add_code_hint()
func _on_undo_hint() -> void:
	var edit := EditManager.get_edit()
	edit.clear_hint()

"

