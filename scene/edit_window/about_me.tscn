[sub_resource type="GDScript" id="GDScript_lv77k"]
script/source = "extends TextureRect

func _ready() -> void:
	texture = load(ProjectSettings.get_setting(\"application/config/icon\")) as Texture2D
"

[sub_resource type="GDScript" id="GDScript_7yhjt"]
script/source = "extends Label

var count := 0

func _gui_input(event: InputEvent) -> void:
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
			count += 1
			if 5 <= count and count < 10:
				var v := remap(count, 5.0, 10.0, 1.0, 0.0)
				add_theme_color_override(\"font_color\", Color(1.0, v, v))
			
			if count == 10:
				text = \"知道了\"
				await get_tree().create_timer(3.0).timeout
				add_theme_color_override.call_deferred(\"font_color\", Color.WHITE)
				set_text.call_deferred(\"F\")

"

[sub_resource type="LabelSettings" id="LabelSettings_j8lag"]
