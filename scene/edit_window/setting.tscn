func _ready() -> void:
	text = FileSystem.data_root
"

[sub_resource type="GDScript" id="GDScript_h0p1a"]
script/source = "extends ColorPickerButton

## 配置名称选择名。
const SELECT_NAME := \"HighLightColor\"
## 颜色名称。
@export var color_name : String

func _ready() -> void:
	visibility_changed.connect(_on_visibility_changed)
	color_changed.connect(_on_color_changed)

func _on_color_changed(col : Color) -> void:
	var config := ConfigFile.new()
	if FileAccess.file_exists(FileSystem.config_path):
		config.load(FileSystem.config_path)
	config.set_value(SELECT_NAME, color_name, col)
	config.save(FileSystem.config_path)
	(get_window() as SettingWindow).set_save_reopen_visible(true)

func _on_visibility_changed() -> void:
	var config : ConfigFile
	if FileAccess.file_exists(FileSystem.config_path):
		config = ConfigFile.new()
		config.load(FileSystem.config_path)
		config = config if config.has_section(SELECT_NAME) else null
	if visible:
		var default := EditManager.get_edit().get_highlight_color(color_name) if EditManager.has_edit() else EditManager.get_edit_default_hightlight_color(color_name)
		color = default if config == null else config.get_value(SELECT_NAME, color_name, default)
"

[sub_resource type="GDScript" id="GDScript_w14fy"]
script/source = "extends CheckBox

## 选择键。
const SELECT_NAME := \"EditBehavior\"

func _on_visibility_changed() -> void:
	if not is_visible_in_tree():
		return
	var config := ConfigFile.new()
	if FileAccess.file_exists(FileSystem.config_path):
		config.load(FileSystem.config_path)
	button_pressed = config.get_value(SELECT_NAME, \"double_input_enabled\", true)

func _pressed() -> void:
	var config := ConfigFile.new()
	if FileAccess.file_exists(FileSystem.config_path):
		config.load(FileSystem.config_path)
	config.set_value(SELECT_NAME, \"double_input_enabled\", button_pressed)
	config.save(FileSystem.config_path)
	if EditManager.has_edit():
		EditManager.get_edit().double_input_disabled = not button_pressed
"

[sub_resource type="GDScript" id="GDScript_iw8q2"]
script/source = "extends AcceptDialog

func _ready() -> void:
	add_cancel_button(\"取消\")

func _on_confirmed() -> void:
	get_tree().quit.call_deferred()
"

