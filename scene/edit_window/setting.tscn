[connection signal="item_selected" from="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/Normal/HBoxContainer/OptionButton" to="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/Normal/HBoxContainer/OptionButton" method="_on_item_selected"]
[connection signal="visibility_changed" from="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/Normal/HBoxContainer/OptionButton" to="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/Normal/HBoxContainer/OptionButton" method="_on_visibility_changed"]
[connection signal="pressed" from="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/Normal/HBoxContainer2/Button" to="SelectedDataRootWindow" method="popup_centered_clamped"]
[connection signal="visibility_changed" from="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/EditBehavior/HBoxContainer/CheckBox" to="VBoxContainer/HSplitContainer/scene_parent/ScrollContainer/MarginContainer/EditBehavior/HBoxContainer/CheckBox" method="_on_visibility_changed"]
[connection signal="pressed" from="VBoxContainer/Button" to="." method="hide"]
[connection signal="close_requested" from="SelectedDataRootWindow" to="SelectedDataRootWindow" method="hide"]
[connection signal="confirmed" from="SelectedDataRootWindow" to="DataRootChangedExitAcceptWindow" method="popup_centered_clamped"]
[connection signal="canceled" from="DataRootChangedExitAcceptWindow" to="DataRootChangedExitAcceptWindow" method="hide"]
[connection signal="close_requested" from="DataRootChangedExitAcceptWindow" to="." method="hide"]
[connection signal="confirmed" from="DataRootChangedExitAcceptWindow" to="DataRootChangedExitAcceptWindow" method="_on_confirmed"]
