[sub_resource type="GDScript" id="GDScript_2n6rp"]
resource_name = "SettingTree"
script/source = "@tool
extends Tree

## 被选中。
signal tree_index_selected(index : int)

## 更新树。
@export_tool_button(\"Update\") var update_tree_item_callable = update_tree_item

enum ItemIndex {
	## 根。
	ROOT,
	
	## 界面。
	UI,
	## 主题。
	UI_NORMAL,
	
	## 编辑器。
	EDIT,
	## 编辑器高亮。
	EDIT_HIGHTLIGHT,
	## 编辑器补全。
	EDIT_COMPLETION,
	## 编辑器光标。
	EDIT_CARET,
	## 编辑器行为。
	EDIT_BEHAVIOR,
}
## 对应的选项。
@export var option_nodes : Array[Control]

## 树节点。
var items : Array[TreeItem]
## 当前场景。
var current_option_node : Control

func _ready() -> void:
	update_tree_item()
	item_selected.connect(_on_item_selected)
	items[ItemIndex.UI_NORMAL].select(0)

func _on_item_selected() -> void:
	var selected := get_selected()
	var index := items.find(selected)
	
	var node := option_nodes[index] if index < option_nodes.size() else null
	if node != null:
		if current_option_node != null:
			current_option_node.hide()
		current_option_node = node
		node.show()
	
	tree_index_selected.emit(index)

## 更新树。
func update_tree_item() -> void:
	clear()
	var root := create_item()
	
	# 界面。
	var ui := root.create_child()
	ui.set_text(0, \"界面\")
	var ui_normal := ui.create_child()
	ui_normal.set_text(0, \"通用\")
	
	# 编辑器。
	var edit := root.create_child()
	edit.set_text(0, \"编辑器\")
	var edit_heightlight := edit.create_child()
	edit_heightlight.set_text(0, \"高亮\")
	var edit_completion := edit.create_child()
	edit_completion.set_text(0, \"补全\")
	var edit_caret := edit.create_child()
	edit_caret.set_text(0, \"关标\")
	var edit_behavior := edit.create_child()
	edit_behavior.set_text(0, \"行为\")
	
	items = [
		root,
			ui,
				ui_normal,
			edit,
				edit_heightlight,
				edit_completion,
				edit_caret,
				edit_behavior,
	]


"

[sub_resource type="GDScript" id="GDScript_g0qid"]
script/source = "extends OptionButton

const INDEX_SCALES : PackedFloat32Array = [0.5, 0.75, 1.0, 1.25, 1.5, 1.75, 2.0]
const SELECT_NAME := \"UINormal\"

func _on_visibility_changed() -> void:
	if visible:
		var config := ConfigFile.new()
		if FileAccess.file_exists(FileSystem.config_path):
			config.load(FileSystem.config_path)
		select(INDEX_SCALES.find(config.get_value(SELECT_NAME, \"window_scale_factor\", 1.0)))

func _on_item_selected(index: int) -> void:
	var config := ConfigFile.new()
	if FileAccess.file_exists(FileSystem.config_path):
		config.load(FileSystem.config_path)
	var sca := INDEX_SCALES[index]
	config.set_value(SELECT_NAME, \"window_scale_factor\", sca)
	config.save(FileSystem.config_path)
	
	get_viewport().get_window().content_scale_factor = sca
	get_window().popup_centered_clamped()
"

[sub_resource type="GDScript" id="GDScript_bkxbc"]
