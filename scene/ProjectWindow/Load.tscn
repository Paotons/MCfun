[sub_resource type="GDScript" id="GDScript_7vk0i"]
script/source = "extends LineEdit

func _ready() -> void:
	if not FileSystem.is_initialed():
		await FileSystem.initial_finished
	text = ProjectManager.project_list_path

func _on_file_dialog_dir_selected(dir: String) -> void:
	text = dir
"

[sub_resource type="GDScript" id="GDScript_u0kf3"]
script/source = "extends Button

func _get_project_name() -> String:
	return $\"../MarginContainer/MarginContainer/VBoxContainer/HBoxContainer/ProjectName\".text
func _get_project_path() -> String:
	return $\"../MarginContainer/MarginContainer/VBoxContainer/HBoxContainer2/ProjectPath\".text
func get_project_name() -> String:
	return _get_project_name().validate_filename()
func get_project_path() -> String:
	return _get_project_path()

func is_valid() -> bool:
	var nam := get_project_name()
	if not nam.is_valid_filename():
		return false
	
	var path := _get_project_path()
	if not(path.is_absolute_path() or path.is_relative_path()):
		return false
	elif not DirAccess.dir_exists_absolute(ProjectSettings.globalize_path(path)):
		return false
	
	if not FileAccess.file_exists(path.path_join(Project.PROJECT_CONFIG_PATH)):
		return false
	return true

func test_is_vaild() -> void:
	disabled = not is_valid()

func _pressed() -> void:
	if not is_valid():
		return
	var nam := get_project_name()
	var path := get_project_path()
	ProjectManager.add_project_list(nam, path)
	var project := ProjectManager.get_project(nam)
	project.set_project_name(nam)
	get_window().close_requested.emit()

"

[sub_resource type="GDScript" id="GDScript_7nifj"]
script/source = "extends FileDialog

func _ready() -> void:
	if not FileSystem.is_initialed():
		await FileSystem.initial_finished
	current_dir = ProjectManager.project_list_path
"

